{
  "name": "sagason-products-lambda",
  "version": "1.0.0",
  "description": "Lambda para gestión de precios de productos SAGASON SPA",
  "type": "module",
  "main": "index.mjs",
  "scripts": {
    "build": "zip -r ../lambda-products.zip . --exclude '*.zip' --exclude 'node_modules/.cache/*'",
    "deploy": "aws lambda update-function-code --function-name sagason-products-prices --zip-file fileb://../lambda-products.zip"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0"
  }
}
